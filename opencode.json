{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": ["rules/guidelines.md"],
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "carlogtt-conduit-dev"
      }
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CARLOGTT_SECRET_CONTEXT7_API_KEY}"
      }
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GH_TOKEN}"
      }
    },
    "firecrawl": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.firecrawl.dev/{env:CARLOGTT_SECRET_FIRECRAWL_API_KEY}/v2/mcp"
    }
  },
  "plugin": [],
  "tools": {
    "*": true,
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "find *": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "ask",
    "write": "ask",
    "patch": "ask",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "question": "allow",
    "external_directory": {
      "*": "ask",
      "$HOME/.config/opencode/**": "allow"
    },
    "doom_loop": "ask",
    "project": "allow"
  },
  "compaction": {
    "auto": false,
    "prune": false
  }
}
